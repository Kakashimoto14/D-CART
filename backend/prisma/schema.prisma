generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKING
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryAssignmentStatus {
  ASSIGNED
  PICKED_UP
  DELIVERED
  FAILED
  CANCELLED
}

enum DeliveryType {
  STANDARD
  SAME_DAY
}

enum PaymentMethod {
  COD
  GCASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum InventoryBatchStatus {
  ACTIVE
  NEAR_EXPIRY
  EXPIRED
  QUARANTINED
  DEPLETED
}

enum InventoryReservationStatus {
  ACTIVE
  COMMITTED
  RELEASED
  EXPIRED
}

enum InventoryMovementType {
  RECEIVE
  RESERVE
  RELEASE
  COMMIT
  ADJUST
  DAMAGE
  EXPIRE
  RETURN
}

enum PickStatus {
  PENDING
  PICKED
  PARTIAL
  UNAVAILABLE
  SUBSTITUTED
}

enum SubstitutionPreference {
  BEST_MATCH
  ASK_BEFORE_REPLACE
  NO_SUBSTITUTIONS
}

enum SubstitutionDecision {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum RefundStatus {
  NONE
  PENDING
  NOT_REQUIRED
  COMPLETED
}

enum NotificationChannel {
  EMAIL
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

model User {
  id                     Int               @id @default(autoincrement())
  name                   String
  email                  String            @unique
  password               String?
  authProvider           AuthProvider      @default(LOCAL)
  googleSub              String?           @unique @db.VarChar(255)
  avatarUrl              String?           @db.VarChar(500)
  emailVerifiedAt        DateTime?
  phone                  String?           @db.VarChar(20)
  role                   Role              @default(CUSTOMER)
  passwordResetToken     String?           @db.VarChar(64)
  passwordResetExpiresAt DateTime?
  cart                   Cart?
  orders                 Order[]
  pickerAssignments      Order[]           @relation("PickerOrders")
  riderProfile           Rider?
  refreshTokens          RefreshToken[]
  auditLogs              AuditLog[]        @relation("AuditLogActor")
  notificationLogs       NotificationLog[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([authProvider])
  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?   @db.VarChar(500)
  image       String?   @db.VarChar(500)
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id                        Int                        @id @default(autoincrement())
  name                      String
  description               String?                    @db.Text
  image                     String?                    @db.VarChar(500)
  price                     Decimal                    @db.Decimal(10, 2)
  stock                     Int
  unit                      String                     @default("pc") @db.VarChar(20)
  weight                    Decimal?                   @db.Decimal(10, 3)
  barcode                   String?                    @unique @db.VarChar(50)
  categoryId                Int
  category                  Category                   @relation(fields: [categoryId], references: [id])
  orderItems                OrderItem[]
  cartItems                 CartItem[]
  inventoryItem             InventoryItem?
  inventoryReservationItems InventoryReservationItem[]
  inventoryMovements        InventoryMovement[]
  substitutedItems          OrderItem[]                @relation("SubstituteProduct")
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@index([categoryId])
  @@map("products")
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id                     Int                    @id @default(autoincrement())
  userId                 Int
  subtotal               Decimal                @default(0) @db.Decimal(10, 2)
  deliveryFee            Decimal                @default(0) @db.Decimal(10, 2)
  total                  Decimal                @db.Decimal(10, 2)
  status                 OrderStatus            @default(PENDING)
  substitutionPreference SubstitutionPreference @default(BEST_MATCH)
  paymentMethod          PaymentMethod          @default(COD)
  paymentStatus          PaymentStatus          @default(PENDING)
  paymentProvider        String?                @db.VarChar(50)
  paymentReference       String?                @db.VarChar(100)
  paymentCheckoutId      String?                @db.VarChar(100)
  refundStatus           RefundStatus           @default(NONE)
  refundAmount           Decimal                @default(0) @db.Decimal(10, 2)
  fulfillmentAdjustedAt  DateTime?
  inventoryReservationId Int?                   @unique
  paidAt                 DateTime?
  pickerId               Int?
  pickerNotes            String?                @db.Text
  packedAt               DateTime?
  packedByUserId         Int?
  stagingLabel           String?                @db.VarChar(100)
  stagingZone            String?                @db.VarChar(100)
  readyForDispatchAt     DateTime?
  deliverySlotId         Int?
  user                   User                   @relation(fields: [userId], references: [id])
  picker                 User?                  @relation("PickerOrders", fields: [pickerId], references: [id])
  deliverySlot           DeliverySlot?          @relation(fields: [deliverySlotId], references: [id])
  inventoryReservation   InventoryReservation?  @relation("OrderInventoryReservation", fields: [inventoryReservationId], references: [id])
  items                  OrderItem[]
  delivery               Delivery?
  notificationLogs       NotificationLog[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@index([userId])
  @@index([pickerId])
  @@index([deliverySlotId])
  @@index([paymentCheckoutId])
  @@index([inventoryReservationId])
  @@map("orders")
}

model OrderItem {
  id                   Int                  @id @default(autoincrement())
  orderId              Int
  productId            Int
  quantity             Int
  price                Decimal              @db.Decimal(10, 2)
  pickedQty            Int                  @default(0)
  finalQuantity        Int                  @default(0)
  pickStatus           PickStatus           @default(PENDING)
  substitutionDecision SubstitutionDecision @default(NONE)
  pickedAt             DateTime?
  pickedByUserId       Int?
  scannedBarcode       String?              @db.VarChar(50)
  pickIssueNote        String?              @db.VarChar(255)
  substituteProductId  Int?
  substitutionNote     String?              @db.VarChar(255)
  order                Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product              Product              @relation(fields: [productId], references: [id])
  substituteProduct    Product?             @relation("SubstituteProduct", fields: [substituteProductId], references: [id])
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([substituteProductId])
  @@map("order_items")
}

model Delivery {
  id          Int                  @id @default(autoincrement())
  orderId     Int                  @unique
  address     String
  latitude    Decimal?             @db.Decimal(10, 7)
  longitude   Decimal?             @db.Decimal(10, 7)
  distanceKm  Decimal?             @db.Decimal(10, 2)
  deliveryFee Decimal              @default(0) @db.Decimal(10, 2)
  status      DeliveryStatus       @default(PENDING)
  type        DeliveryType         @default(SAME_DAY)
  estimatedAt DateTime?
  order       Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignments DeliveryAssignment[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("deliveries")
}

model DeliverySlot {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  startTime   String   @db.VarChar(5)
  endTime     String   @db.VarChar(5)
  maxOrders   Int      @default(5)
  bookedCount Int      @default(0)
  isActive    Boolean  @default(true)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, startTime, endTime])
  @@map("delivery_slots")
}

model StoreConfig {
  id             Int     @id @default(autoincrement())
  storeName      String  @default("Decolores Grocery Store")
  latitude       Decimal @db.Decimal(10, 7)
  longitude      Decimal @db.Decimal(10, 7)
  deliveryRadius Decimal @default(5.0) @db.Decimal(5, 1)
  baseFee        Decimal @default(30.00) @db.Decimal(10, 2)
  perKmFee       Decimal @default(10.00) @db.Decimal(10, 2)

  @@map("store_config")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int
  tokenHash  String    @unique @db.VarChar(64)
  expiresAt  DateTime
  revokedAt  DateTime?
  deviceInfo String?   @db.VarChar(255)
  ipAddress  String?   @db.VarChar(64)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  actorUserId  Int?
  action       String   @db.VarChar(100)
  entityType   String   @db.VarChar(100)
  entityId     String?  @db.VarChar(100)
  beforeJson   Json?
  afterJson    Json?
  ipAddress    String?  @db.VarChar(64)
  metadataJson Json?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@map("audit_logs")
}

model InventoryItem {
  id             Int              @id @default(autoincrement())
  productId      Int              @unique
  onHandQty      Int              @default(0)
  reservedQty    Int              @default(0)
  availableQty   Int              @default(0)
  reorderPoint   Int              @default(0)
  reorderQty     Int              @default(0)
  safetyStockQty Int              @default(0)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  product        Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  batches        InventoryBatch[]

  @@index([availableQty, isActive])
  @@map("inventory_items")
}

model InventoryBatch {
  id               Int                        @id @default(autoincrement())
  inventoryItemId  Int
  batchCode        String                     @unique @db.VarChar(100)
  supplier         String?                    @db.VarChar(150)
  receivedAt       DateTime
  expiresAt        DateTime?
  unitCost         Decimal?                   @db.Decimal(10, 2)
  receivedQty      Int
  remainingQty     Int
  status           InventoryBatchStatus       @default(ACTIVE)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  inventoryItem    InventoryItem              @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  reservationItems InventoryReservationItem[]
  movements        InventoryMovement[]

  @@index([inventoryItemId, status, expiresAt])
  @@map("inventory_batches")
}

model InventoryReservation {
  id              Int                        @id @default(autoincrement())
  cartSessionKey  String?                    @db.VarChar(100)
  status          InventoryReservationStatus @default(ACTIVE)
  expiresAt       DateTime
  createdByUserId Int?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  order           Order?                     @relation("OrderInventoryReservation")
  items           InventoryReservationItem[]

  @@index([status, expiresAt])
  @@map("inventory_reservations")
}

model InventoryReservationItem {
  id            Int                  @id @default(autoincrement())
  reservationId Int
  productId     Int
  batchId       Int
  quantity      Int
  createdAt     DateTime             @default(now())
  reservation   InventoryReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  batch         InventoryBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([productId])
  @@index([batchId])
  @@map("inventory_reservation_items")
}

model InventoryMovement {
  id            Int                   @id @default(autoincrement())
  productId     Int
  batchId       Int?
  type          InventoryMovementType
  quantityDelta Int
  referenceType String?               @db.VarChar(50)
  referenceId   String?               @db.VarChar(100)
  reason        String?               @db.VarChar(255)
  actorUserId   Int?
  metadataJson  Json?
  createdAt     DateTime              @default(now())
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  batch         InventoryBatch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([batchId, createdAt])
  @@map("inventory_movements")
}

model Rider {
  id               Int                  @id @default(autoincrement())
  userId           Int                  @unique
  vehicleType      String               @db.VarChar(50)
  isActive         Boolean              @default(true)
  isAvailable      Boolean              @default(true)
  currentLatitude  Decimal?             @db.Decimal(10, 7)
  currentLongitude Decimal?             @db.Decimal(10, 7)
  lastSeenAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments      DeliveryAssignment[]

  @@index([isActive, isAvailable])
  @@map("riders")
}

model DeliveryAssignment {
  id            Int                      @id @default(autoincrement())
  deliveryId    Int
  riderId       Int
  status        DeliveryAssignmentStatus @default(ASSIGNED)
  assignedAt    DateTime                 @default(now())
  pickedUpAt    DateTime?
  recipientName String?                  @db.VarChar(100)
  proofNote     String?                  @db.VarChar(255)
  completedAt   DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  delivery      Delivery                 @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  rider         Rider                    @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([deliveryId, status])
  @@index([riderId, status])
  @@map("delivery_assignments")
}

model NotificationLog {
  id            Int                 @id @default(autoincrement())
  orderId       Int?
  userId        Int?
  channel       NotificationChannel
  templateKey   String              @db.VarChar(100)
  recipient     String              @db.VarChar(255)
  subject       String              @db.VarChar(255)
  status        NotificationStatus
  provider      String              @db.VarChar(50)
  retryCount    Int                 @default(0)
  lastRetriedAt DateTime?
  errorMessage  String?             @db.VarChar(255)
  payloadJson   Json?
  sentAt        DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  order         Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  user          User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([templateKey, createdAt])
  @@map("notification_logs")
}
